---
// src/pages/index.astro
// Import the Layout and all your section components
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';
import AboutUs from '../components/AboutUs.astro';
import Services from '../components/Services.astro';
import PartnerAirlines from '../components/PartnerAirlines.astro';
import Clients from '../components/Clients.astro';
import EnquiryForm from '../components/EnquiryForm.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Areej Travel & Tours">
	<Header />
	<Nav />
	
	<!-- Astro will inject these sections sequentially into the Layout's <slot /> -->
	<div id="main">
		<AboutUs />
		<Services />
		<PartnerAirlines />
		<Clients />
		<EnquiryForm />
	</div>

	<Footer />
</BaseLayout>