---
// src/layouts/BaseLayout.astro
// The frontmatter (between the --- lines) is where server-side JavaScript/TypeScript runs.
// We define a 'title' prop so each page can inject its own tab title.
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<html lang="en">
	<head>
		<title>{title}</title>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no" />
		
		<!-- 
			Assets placed in the public/ folder are referenced directly from the root '/'. 
			Astro does not bundle these; it serves them exactly as they are.
		-->
		<link rel="stylesheet" href="/assets/css/main.css" />
		<noscript><link rel="stylesheet" href="/assets/css/noscript.css" /></noscript>

		<!-- Modern Favicon Configuration Pack Setup -->
		<!-- Classic root fallback for legacy browsers -->
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		
		<!-- Standard desktop browser tabs (PNG specification) -->
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		
		<!-- Apple touch icons (Safari bookmarks & home screens) -->
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		
		<!-- High-resolution Android and web app shortcut fallbacks -->
		<link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png" />
		<link rel="icon" type="image/png" sizes="512x512" href="/android-chrome-512x512.png" />
	</head>
	<body class="is-preload">

		<div id="wrapper">
			<!-- 
				The <slot /> is Astro's magic keyword. 
				Whatever content you wrap inside <BaseLayout> on your actual pages 
				will be injected exactly where this <slot /> tag is.
			-->
			<slot />
		</div>

		<!-- 
			The is:inline directive tells Astro NOT to bundle or process these scripts.
			Because this template relies heavily on legacy jQuery plugins, keeping them inline 
			ensures they load in the exact order required without Astro's module bundler breaking them.
		-->
		<script is:inline src="/assets/js/jquery.min.js"></script>
		<script is:inline src="/assets/js/jquery.scrollex.min.js"></script>
		<script is:inline src="/assets/js/jquery.scrolly.min.js"></script>
		<script is:inline src="/assets/js/browser.min.js"></script>
		<script is:inline src="/assets/js/breakpoints.min.js"></script>
		<script is:inline src="/assets/js/util.js"></script>
		<script is:inline src="/assets/js/main.js"></script>

		<!-- External API script for the form captcha -->
		<script is:inline src="https://web3forms.com/client/script.js" async defer></script>
	</body>
</html>