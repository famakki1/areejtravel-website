  { src: "/images/airlines/eurowings.svg", alt: "Eurowings" },
  { src: "/images/airlines/turkish.svg", alt: "Turkish Airlines" },
  { src: "/images/airlines/qatar.svg", alt: "Qatar Airways" },
  { src: "/images/airlines/azerbaijanairlines.svg", alt: "Azerbaijan Airlines" },
  { src: "/images/airlines/ethiopian.svg", alt: "Ethiopian Airlines" },
